{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  // Giá trị thật nạp từ user-secrets (dev) hoặc biến môi trường ConnectionStrings__AppDb (prod)
  "ConnectionStrings": {
    "AppDb": ""
  },
  "Jwt": {
    "Issuer": "qtht-api",
    "Audience": "qtht-client",
    // SecretKey nạp từ user-secrets (dev) / biến môi trường Jwt__SecretKey (prod).
    // TUYỆT ĐỐI không điền giá trị vào đây — file này nằm trong git.
    "SecretKey": "",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  }
}
