{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "qtht-route": {
        "ClusterId": "qtht-cluster",
        "Match": {
          "Path": "/qtht/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/qtht" }
        ]
      }
    },
    "Clusters": {
      "qtht-cluster": {
        "Destinations": {
          "qtht-1": {
            "Address": "http://localhost:5219/"
          }
        }
      }
    }
  }
}
